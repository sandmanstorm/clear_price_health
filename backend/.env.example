# ClearPrice Backend Environment
# Copy to .env and fill in values. Never commit .env.

# === App ===
APP_NAME=ClearPrice
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_python3 -c "import secrets; print(secrets.token_hex(64))"
ENCRYPTION_KEY=CHANGE_ME_python3 -c "import secrets; print(secrets.token_hex(64))"
FRONTEND_URL=https://clearpricehealth.org
BACKEND_URL=http://10.10.100.33:8000

# === Database ===
# Replace password and host/port to match your setup
DATABASE_URL=postgresql+asyncpg://clearprice:CHANGE_ME@localhost:5432/clearprice
DATABASE_URL_SYNC=postgresql+psycopg2://clearprice:CHANGE_ME@localhost:5432/clearprice

# === Redis (with requirepass) ===
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@localhost:6379/2

# === Auth ===
JWT_SECRET_KEY=CHANGE_ME_python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Managed via Admin UI (left empty as fallback) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://clearpricehealth.org/api/auth/google/callback

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

SMTP_HOST=box.netplak.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clearpricehealth.org

# === Admin bootstrap (creates first admin on init) ===
FIRST_ADMIN_EMAIL=admin@clearpricehealth.org
FIRST_ADMIN_PASSWORD=CHANGE_ME
